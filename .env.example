# Telegram
BOT_TOKEN=your-telegram-bot-token
ADMIN_IDS=123456789

# Database
# For local SQLite dev mode leave DB_HOST empty
DB_HOST=
DB_PORT=5432
DB_USER=fitness_bot
DB_PASSWORD=fitness_bot_secret
DB_NAME=fitness_bot

# Redis / FSM
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# App
LOG_LEVEL=INFO
DEBUG=false
