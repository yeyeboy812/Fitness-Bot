# Production env template. Copy to .env on the server and fill real values.
# DO NOT commit the real .env.

# Telegram
BOT_TOKEN=
COLLECTOR_BOT_TOKEN=
CONTEXT_BOT_TOKEN=
ADMIN_IDS=

# Database — DB_HOST must match compose service name
DB_HOST=postgres
DB_PORT=5432
DB_USER=fitness_bot
DB_PASSWORD=change-me-strong-password
DB_NAME=fitness_bot

# Redis / FSM
USE_REDIS=true
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# App
LOG_LEVEL=INFO
DEBUG=false
